<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="life.catalogue.db.mapper.NamesIndexMapper">

  <sql id="SELECT">
    id, <include refid="life.catalogue.db.mapper.NamesIndexMapper.COLS"/>, created, modified
  </sql>

  <sql id="COLS">
    scientific_name,
    normalized,
    uninomial,
    genus,
    infrageneric_epithet,
    specific_epithet,
    infraspecific_epithet,
    cultivar_epithet
  </sql>

  <sql id="PROPS">
    #{scientificName},
    #{normalized},
    #{uninomial},
    #{genus},
    #{infragenericEpithet},
    #{specificEpithet},
    #{infraspecificEpithet},
    #{cultivarEpithet}
  </sql>

  <sql id="FROM">names_index n</sql>

  <!-- A mapping to the single-tier, canonical-only IndexName, mostly auto mapped -->
  <resultMap id="nameResultMap" type="IndexName" autoMapping="true">
    <id property="key" column="id"/>
  </resultMap>

  <resultMap id="simpleNameResultMap" type="SimpleName" autoMapping="false">
    <id property="id" column="ids"/>
    <result property="name" column="scientific_name"/>
  </resultMap>

  <select id="get" resultMap="nameResultMap">
    SELECT <include refid="SELECT"/>
    FROM <include refid="FROM"/>
    WHERE id = #{key}
  </select>

  <insert id="create" parameterType="IndexName" useGeneratedKeys="true" keyProperty="key">
    INSERT INTO names_index (<include refid="COLS"/>, created, modified)
    VALUES (<include refid="PROPS"/>, now(), now())
  </insert>

  <!--
    Atomic assign-on-miss: only one row per normalized bucket key can ever exist (enforced by the unique
    names_index_normalized_idx). On a fresh insert pgjdbc returns the generated id and MyBatis sets it on
    the IndexName.key; on a conflict DO NOTHING inserts nothing, RETURNING yields no row, and key stays null
    so the caller falls back to getKeyByNormalized to fetch the existing winner.
  -->
  <insert id="createOnConflict" parameterType="IndexName" useGeneratedKeys="true" keyProperty="key" keyColumn="id">
    INSERT INTO names_index (<include refid="COLS"/>, created, modified)
    VALUES (<include refid="PROPS"/>, now(), now())
    ON CONFLICT (normalized) DO NOTHING
    RETURNING id
  </insert>

  <select id="getKeyByNormalized" resultType="integer">
    SELECT id FROM names_index WHERE normalized = #{normalized}
  </select>

  <update id="update" parameterType="IndexName" keyProperty="key">
    UPDATE names_index
    SET (<include refid="COLS"/>, created, modified) =
        (<include refid="PROPS"/>, now(), now())
    WHERE id = #{key}
  </update>

  <delete id="delete" parameterType="map">
    DELETE FROM names_index
    WHERE id = #{key}
  </delete>

  <select id="processAll" parameterType="map" resultMap="nameResultMap" resultOrdered="true" fetchSize="2500" resultSetType="FORWARD_ONLY">
    SELECT <include refid="SELECT"/>
    FROM <include refid="FROM"/>
  </select>

  <select id="count" parameterType="map" resultType="integer">
    SELECT count(*) FROM names_index
  </select>

  <update id="truncate">
    TRUNCATE names_index RESTART IDENTITY CASCADE
  </update>

  <update id="updateSequence">
    SELECT setval('names_index_id_seq', (SELECT COALESCE(max(id),1) FROM names_index))
  </update>

  <select id="listByRegex" parameterType="map" resultMap="nameResultMap">
    SELECT <include refid="SELECT"/>
    FROM <include refid="FROM"/>
    WHERE scientific_name ~ '^${regex}'
    ORDER BY scientific_name, id
    <include refid="life.catalogue.db.Common.limit"/>
  </select>

  <select id="processDatasets" parameterType="map" resultMap="simpleNameResultMap" resultOrdered="true" fetchSize="1000" resultSetType="FORWARD_ONLY">
    SELECT n.scientific_name, jsonb_object_agg(u.dataset_key, u.id) as ids
    FROM names_index n JOIN name_match nm ON n.id=nm.index_id JOIN name_usage u ON u.dataset_key = nm.dataset_key AND u.name_id = nm.name_id
    WHERE nm.dataset_key IN <foreach item="key" collection="datasetKeys" open="(" separator="," close=")">#{key}</foreach>
    GROUP BY n.scientific_name
    <if test="minDatasets != null and minDatasets > 0">
      HAVING count(u.dataset_key) >= #{minDatasets}
    </if>
    ORDER BY n.scientific_name
  </select>

</mapper>
